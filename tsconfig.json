{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "types": ["node", "@playwright/test", "vite/client"]
  },
  "include": ["apps/**/*.ts", "apps/**/*.tsx", "tests/**/*.ts"]
}
